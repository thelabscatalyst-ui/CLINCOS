# Core
DATABASE_URL=sqlite:///./clinic.db
SECRET_KEY=replace-with-random-32-char-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Twilio — WhatsApp/SMS notifications (optional for local dev)
# Get from: console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=

# Razorpay — payments (optional for local dev)
# Get from: dashboard.razorpay.com > Settings > API Keys
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# Admin panel — must match the email of your registered doctor account
ADMIN_EMAIL=your-email@example.com
